{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AmazonWebServiceConstants": {
    "BucketName": "yume-song",
    "SongTableName": "Music",
    "UserTableName": "User",
    "AwsRegion": "ap-south-1", // ENV
    "AccessKey": "access_key_here", // ENV
    "SecretKey": "secret_key" // ENV
  },
  "JwtConstants": {
    "Key": "your_jwt_secret_key_here", // ENV
    "Issuer": "your_issuer_here", // ENV
    "Audience": "your_audience_here", // ENV
    "DurationInHours": 60
  }
}