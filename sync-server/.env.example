# ──────────────────────────────────────────────────────────────────────
# Hikari Sync Server — docker-compose environment
# Copy to `.env` (Copy-Item .env.example .env) and adjust as needed.
# Every value has a sensible dev default in docker-compose.yml, so the
# stack also runs with no .env at all — but DO override secrets for anything
# beyond local experimentation.
# ──────────────────────────────────────────────────────────────────────

# ── MongoDB ──
MONGO_ROOT_USERNAME=hikari
MONGO_ROOT_PASSWORD=hikari-mongo-pw
MONGODB_DATABASE=hikari
MONGO_PORT=27017

# ── MinIO ──
MINIO_ROOT_USER=hikari
MINIO_ROOT_PASSWORD=hikari-minio-pw
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
OBJECT_STORAGE_BUCKET=hikari-storage
# Endpoint clients (Android app) use to reach MinIO for presigned upload/download.
#   • Same machine / browser:   http://localhost:9000
#   • Android emulator:         http://10.0.2.2:9000
#   • Physical device on LAN:   http://<your-lan-ip>:9000
OBJECT_STORAGE_PUBLIC_SERVICE_URL=http://localhost:9000

# ── API ──
SYNC_SERVER_PORT=8080

# ── SMB / CIFS share backing MinIO object data (optional) ──
# Leave SMB_HOST empty (default) → MinIO uses a normal local Docker volume.
# Set SMB_HOST (+ the fields below) → MinIO's /data is mounted from
# //${SMB_HOST}/${SMB_SHARE_PATH} on your SMB server. No extra compose file:
# the main docker-compose.yml switches the minio-data volume to CIFS automatically.
# (After switching an existing local volume to SMB, run `docker compose down -v` once.)
SMB_HOST=                          # e.g. 192.168.1.10 — empty = local volumes (no SMB)
SMB_SHARE_PATH=hikari/minio        # share name + optional subfolder for MinIO data
SMB_USERNAME=smbuser
SMB_PASSWORD=smbpassword
SMB_VERSION=3.0                    # CIFS protocol: 3.1.1 / 3.0 / 2.1
SMB_UID=0                          # owner uid for share files (services run as root → 0)
SMB_GID=0
# Optional extra CIFS mount options, comma-separated (no leading comma), e.g.
#   sec=ntlmssp,noserverino
SMB_EXTRA_OPTS=

# Optionally also back MongoDB data with the SMB share (uses SMB_HOST + the creds above).
# ⚠ NOT recommended: MongoDB's WiredTiger engine relies on file locking + memory mapping
# that network filesystems don't guarantee, which can corrupt the database — keep Mongo on
# a local volume unless you really know your share supports it. Separate opt-in: setting
# SMB_HOST alone moves only MinIO; Mongo stays local until you ALSO set the path below.
MONGO_SMB_SHARE_PATH=              # e.g. hikari/mongo — empty = Mongo stays on a local volume


# ── Auth (JWT_KEY MUST be at least 32 bytes — the server refuses to start otherwise) ──
JWT_KEY=change-me-to-at-least-32-bytes-of-entropy!!
JWT_ISSUER=Hikari-sync-server
JWT_AUDIENCE=Hikari-mobile-app
JWT_DURATION_HOURS=12

# ── Bootstrap root (first-login seed; override the password for real use) ──
BOOTSTRAP_ADMIN_USERNAME=root
BOOTSTRAP_ADMIN_PASSWORD=Root123!
